OPENAI_API_KEY=your_api_key_here

# ── Tier-раскладка моделей (все переменные опциональны) ─────────────────────
# Дефолт без переменных: gpt-4.1-mini на всех стадиях (текущее поведение).
#
# Tier A — ответственные проходы: spine (хребет с развилками), castPlan
#          (агенды персонажей), storyLeafQA (критик листьев веток).
# Tier B — структурный JSON: worldCalendar, eventPool, beatPlan, anchorBeat,
#          ending, dialogueQA, outline, worldModel, liCards.
# Tier C — массовая проза: dialogueUnit, dialogueVariant, segment, sceneText,
#          storyMasterPrompt, narrationWeb.
#
# Рекомендация (research июль-2026, ~$2.9/история; только OpenAI):
#TEXTGEN_MODEL_TIER_A=gpt-5.6-terra
#TEXTGEN_MODEL_TIER_B=gpt-5.4-mini
#TEXTGEN_MODEL_TIER_C=gpt-5.4-mini
# Эксперимент для прозы (дешевле ~в 3 раза, русскую прозу проверить на глаз):
#TEXTGEN_MODEL_TIER_C=gpt-5.4-nano

# Точечное переопределение одной стадии бьёт tier-переменную:
#TEXTGEN_MODEL_SPINE=gpt-5.6-sol
#TEXTGEN_MODEL_DIALOGUEUNIT=gpt-5.4-mini
