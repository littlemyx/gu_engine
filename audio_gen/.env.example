# Ключ Suno API (https://sunoapi.org)
SUNO_API_KEY=your_suno_api_key_here

# Адрес audio_server (хранилище mp3)
AUDIO_SERVER_URL=http://localhost:3008

# DigitalOcean Spaces (S3-совместимый бакет) — обязателен для генерации
# вариаций: Suno upload-cover скачивает исходный трек по публичному URL,
# localhost ему недоступен. Бакет может оставаться приватным — используется
# presigned GET URL с TTL 1 час.
# Пример endpoint: https://fra1.digitaloceanspaces.com (без имени бакета)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
